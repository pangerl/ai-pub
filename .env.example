# AI Pub Compose 部署环境变量。
# 使用方式：复制为 deploy/.env，然后按实际部署修改。

# 常用可选项：仅当服务器 18080 端口已被占用时修改。
APP_PORT=18080

# 共享环境、公网环境或长期使用时必须改成强随机值。
# 可用 `openssl rand -hex 32` 生成。
APP_ENCRYPTION_KEY=replace-with-random-hex-32
JWT_SECRET=replace-with-random-hex-32

# 初始管理员。用户名可按需修改，密码必须改成强密码。
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-admin-password

# 公网 demo 入口账号保护；compose.demo.yaml 会启用 DEMO_MODE。
# 多个用户名用英文逗号分隔。
DEMO_PROTECTED_USERNAMES=demo

# 可选：固定发布镜像 tag；不设置时使用 hxjagf/ai-pub:latest。
# AI_PUB_IMAGE=hxjagf/ai-pub:latest

# 部署方式由 compose.*.yaml 决定，通常不需要在这里设置
# DB_DIALECT、MYSQL_DSN、WORKER_ENABLED、DEMO_MODE 或 EXECUTOR_*。
