# Local compose defaults. Copy to .env and change all secrets before any shared or production use.

APP_PORT=18080

APP_ENCRYPTION_KEY=replace-with-a-long-random-encryption-key
JWT_SECRET=replace-with-a-long-random-jwt-secret

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-admin-password

# deploy/compose.mysql.yaml provides DB_DIALECT=mysql and MYSQL_DSN inside the app container.
# Set these only when running the backend outside the bundled Compose network.
# DB_DIALECT=mysql
# MYSQL_DSN=ai_pub:ai_pub@tcp(mysql:3306)/ai_pub?parseTime=true&charset=utf8mb4&loc=UTC
# SQLITE_PATH=data/ai-pub.db
# APP_ENV=prod
# MIGRATION_AUTO=true
# MIGRATION_CHECK_ONLY=false
# WORKER_ENABLED=true
# EXECUTOR_SSH_DISABLED=false
# EXECUTOR_K8S_DISABLED=false
# Demo 公网部署（叠加 deploy/compose.demo.yaml）应设：
#   EXECUTOR_SSH_DISABLED=true
#   EXECUTOR_K8S_DISABLED=true
# 三个密钥变量在 demo compose 中用 ${VAR:?msg} 强制非空，未设或为空则 compose 直接报错不启动。
